global:
  scrape_interval: 15s
  evaluation_interval: 10s
scrape_configs:
  - job_name: "prometheus"
    scrape_interval: 5s
    static_configs:
      - targets: ["host.docker.internal:${PROMETHEUS_PORT}"]
  - job_name: "pushgateway"
    scrape_interval: 5s
    static_configs:
      - targets: ["host.docker.internal:${PUSHGATEWAY_PORT}"]
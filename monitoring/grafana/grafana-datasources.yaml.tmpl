datasources:
- name: prometheus-datasource
  access: 'proxy'
  editable: true
  is_default: true
  org_id: 1
  type: prometheus
  url: 'http://host.docker.internal:${PROMETHEUS_PORT}'
  version: 1
- name: redis-datasource
  type: redis-datasource
  access: proxy
  orgId: 1
  version: 1
  url: redis://host.docker.internal:${REDIS_PORT}
  jsonData:
    poolSize: 5
    timeout: 10
    pingInterval: 0
    pipelineWindow: 0
  editable: true